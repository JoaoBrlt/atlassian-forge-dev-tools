{
  "name": "atlassian-forge-dev-tools",
  "version": "1.0.0",
  "description": "Browser extension that provides DevTools for Atlassian Forge apps.",
  "license": "GPL-3.0-only",
  "author": "João Brilhante",
  "homepage": "https://github.com/JoaoBrlt/atlassian-forge-dev-tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoaoBrlt/atlassian-forge-dev-tools.git"
  },
  "bugs": "https://github.com/JoaoBrlt/atlassian-forge-dev-tools/issues",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist/",
    "check-updates": "ncu",
    "update": "ncu -i",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.33.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@emotion/react": "^11.14.0",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-codemirror": "^4.25.4",
    "http-status-codes": "^2.3.0",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@juggle/resize-observer": "^3.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/eslint-plugin": "^1.6.9",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.4.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.17"
  }
}
